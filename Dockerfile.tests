FROM node:22-bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        chromium chromium-driver \
        ca-certificates fonts-liberation \
        default-jre-headless && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY tsconfig.json wdio.conf.ts ./
COPY tests ./tests

ENV CHROME_BIN=/usr/bin/chromium \
    CHROMEDRIVER_BIN=/usr/bin/chromedriver

# Run the suite, then build the Allure HTML report inside the container (no host Java
# needed). The report is generated even when tests fail, and the WDIO exit code is
# preserved so the run still reports red. `allure-report/` is mounted out via compose.
CMD ["sh", "-c", "npx wdio run ./wdio.conf.ts; status=$?; npx allure generate allure-results --clean -o allure-report; exit $status"]